# Copy this file to .env and fill in real values for local development.
# CI and cloud deployments inject these variables directly via their own mechanisms.
# NEVER commit .env to version control.

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=bittree
POSTGRES_PASSWORD=bittree
POSTGRES_DB=bittree
POSTGRES_PORT=5432
DATABASE_URL=postgres://bittree:bittree@localhost:5432/bittree_auth

# -- Auth Service -------------------------------------------------------------
AUTH_SERVICE_PORT=8000

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ── NATS ─────────────────────────────────────────────────────────────────────
NATS_CLIENT_PORT=4222
NATS_MONITOR_PORT=8222

# ── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Observability ────────────────────────────────────────────────────────────
JAEGER_UI_PORT=16686
JAEGER_OTLP_GRPC_PORT=4317
JAEGER_OTLP_HTTP_PORT=4318
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
